{
  "name": "@gymflow/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "doppler run -- next dev",
    "dev:webpack": "doppler run -- next dev",
    "dev:turbo": "doppler run -- next dev --turbopack",
    "dev:stripe": "doppler run -- concurrently -n next,stripe -c cyan,magenta \"next dev --turbopack\" \"stripe listen --forward-to localhost:3000/api/webhooks/stripe\"",
    "dev:local": "next dev --turbopack",
    "dev:next": "doppler run -- next dev --turbopack",
    "build": "doppler run -- next build",
    "start": "doppler run -- next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@gymflow/database": "workspace:*",
    "@gymflow/ui": "workspace:*",
    "@hookform/resolvers": "^3.10.0",
    "@sentry/nextjs": "^10.56.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.108.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "import-in-the-middle": "^3.0.1",
    "lucide-react": "^0.468.0",
    "next": "15.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.78.0",
    "recharts": "^2.15.4",
    "require-in-the-middle": "^8.0.1",
    "resend": "^6.12.4",
    "sonner": "^1.7.4",
    "stripe": "^17.7.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@gymflow/eslint-config": "workspace:*",
    "@gymflow/typescript-config": "workspace:*",
    "@types/node": "^22.19.20",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
