# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────
# Stripe
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ──────────────────────────────────────────────
# Stripe Price IDs (planos: personal | starter | pro)
# ──────────────────────────────────────────────
STRIPE_PRICE_PERSONAL_MONTHLY=price_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...

# ──────────────────────────────────────────────
# Cloudflare Turnstile (anti-bot em rotas públicas)
# ──────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAA...

# ──────────────────────────────────────────────
# Resend (email)
# ──────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@gymflow.app

# ──────────────────────────────────────────────
# Google Places API
# ──────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...

# ──────────────────────────────────────────────
# Sentry (monitoramento de erros)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=gymflow-web
SENTRY_AUTH_TOKEN=sntrys_...    # apenas para CI/build (upload de source maps)

# ──────────────────────────────────────────────
# Upstash Redis (rate limiting)
# ──────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://seu-dominio.com   # produção: deve ser HTTPS. Local: http://localhost:3000
NEXT_PUBLIC_APP_NAME=GymFlow
