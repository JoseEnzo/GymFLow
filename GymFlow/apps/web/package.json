{
  "name": "@gymflow/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "doppler run -- concurrently -n next,stripe -c cyan,magenta \"next dev --turbopack\" \"stripe listen --forward-to localhost:3000/api/webhooks/stripe\"",
